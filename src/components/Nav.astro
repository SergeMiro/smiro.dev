---
const links = [
  { href: '/', label: 'Home' },
  { href: '/agents', label: 'Agents' },
  { href: '/projects', label: 'Projects' },
  { href: '/demos', label: 'Demos' },
  { href: '/blog', label: 'Blog' },
  { href: '/uses', label: 'Uses' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-[var(--color-bg)]/80 border-b border-[var(--color-border)]">
  <!-- Scroll progress -->
  <div
    data-scroll-progress
    class="absolute top-0 left-0 h-[2px] w-full bg-[var(--color-primary)] origin-left"
    style="transform: scaleX(0)"
  ></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 flex items-center justify-between h-14 sm:h-16 relative">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Home" data-prefetch>
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" class="text-[var(--color-primary)]">
        <rect width="36" height="36" rx="8" fill="currentColor" opacity="0.1" />
        <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="currentColor"
          font-family="var(--font-display)" font-size="16" font-weight="700">SM</text>
      </svg>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} data-prefetch
          class:list={[
            'text-sm font-medium tracking-wide transition-colors relative',
            currentPath === link.href ? 'text-[var(--color-primary)]' : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]',
          ]}>
          {link.label}
          {currentPath === link.href && <span class="absolute -bottom-1 left-0 right-0 h-[2px] bg-[var(--color-primary)]" />}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-2 sm:gap-4">
      <button data-theme-toggle
        class="p-3 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center"
        aria-label="Toggle theme">
        <svg class="w-5 h-5 theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg class="w-5 h-5 theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <button data-mobile-toggle aria-expanded="false" aria-controls="mobile-menu"
        class="md:hidden p-3 text-[var(--color-text-muted)] hover:text-[var(--color-text)] relative z-[60] min-w-[44px] min-h-[44px] flex items-center justify-center"
        aria-label="Open menu">
        <svg class="hamburger-icon w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path class="hamburger-top" d="M4 6h16" />
          <path class="hamburger-mid" d="M4 12h16" />
          <path class="hamburger-bot" d="M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu — drop-down panel anchored under nav bar -->
  <div id="mobile-menu" data-mobile-menu data-state="closed"
    class="mobile-menu md:hidden absolute left-0 right-0 top-full"
    aria-hidden="true">
    <div class="mobile-menu-panel mx-3 mt-2 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-[0_24px_60px_-20px_rgba(0,0,0,0.35)] overflow-hidden">
      <ul class="mobile-menu-scroll max-h-[calc(100svh-5rem)] overflow-y-auto overscroll-contain py-2">
        {links.map((link, i) => (
          <li>
            <a href={link.href} data-prefetch data-mobile-link
              style={`--i:${i}`}
              class:list={[
                'mobile-menu-link flex items-center justify-between px-5 py-3.5 text-[15px] font-medium tracking-wide transition-colors',
                currentPath === link.href
                  ? 'text-[var(--color-primary)] bg-[var(--color-surface)]'
                  : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]',
              ]}>
              <span>{link.label}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-40">
                <path d="M9 18l6-6-6-6" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<!-- Outside-nav backdrop so nav's own stacking context doesn't clip it -->
<div data-mobile-backdrop aria-hidden="true"
  class="mobile-backdrop fixed inset-0 z-40 md:hidden"
  style="background: rgba(10,8,6,0.55); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); opacity: 0; pointer-events: none; transition: opacity 0.25s ease;">
</div>

<style>
  /* Hamburger animation */
  .hamburger-top, .hamburger-mid, .hamburger-bot {
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
    transform-origin: center;
  }
  [data-mobile-toggle][aria-expanded="true"] .hamburger-top {
    transform: translateY(6px) rotate(45deg);
  }
  [data-mobile-toggle][aria-expanded="true"] .hamburger-mid {
    opacity: 0;
    transform: scaleX(0.3);
  }
  [data-mobile-toggle][aria-expanded="true"] .hamburger-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu panel animation */
  .mobile-menu {
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-menu-panel {
    transform: translateY(-8px) scale(0.98);
    opacity: 0;
    transform-origin: top right;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.22s ease, visibility 0.32s;
  }
  .mobile-menu[data-state="open"] {
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-menu[data-state="open"] .mobile-menu-panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* Staggered link reveal */
  .mobile-menu-link {
    opacity: 0;
    transform: translateX(12px);
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22,1,0.36,1), color 0.2s ease, background-color 0.2s ease;
    transition-delay: calc(var(--i, 0) * 40ms);
  }
  .mobile-menu[data-state="open"] .mobile-menu-link {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-backdrop[data-state="open"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* When menu open, lock background scroll (also reinforced via JS) */
  html.menu-open, body.menu-open {
    overflow: hidden;
    touch-action: none;
  }
</style>

<script>
  function initNav() {
    const toggleBtn = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    const backdrop = document.querySelector<HTMLElement>('[data-mobile-backdrop]');
    const themeBtn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

    // Idempotent: skip if already wired on this DOM
    if (toggleBtn && !(toggleBtn as any).__navBound) {
      (toggleBtn as any).__navBound = true;

      let lastScrollY = 0;
      const setOpen = (open: boolean) => {
        if (!menu || !backdrop || !toggleBtn) return;
        menu.dataset.state = open ? 'open' : 'closed';
        backdrop.dataset.state = open ? 'open' : 'closed';
        menu.setAttribute('aria-hidden', String(!open));
        toggleBtn.setAttribute('aria-expanded', String(open));
        toggleBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        if (open) {
          lastScrollY = window.scrollY;
          document.documentElement.classList.add('menu-open');
          document.body.classList.add('menu-open');
          // Preserve visual scroll position while locked.
          document.body.style.position = 'fixed';
          document.body.style.top = `-${lastScrollY}px`;
          document.body.style.left = '0';
          document.body.style.right = '0';
          document.body.style.width = '100%';
        } else {
          document.documentElement.classList.remove('menu-open');
          document.body.classList.remove('menu-open');
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.width = '';
          window.scrollTo(0, lastScrollY);
        }
      };

      toggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = toggleBtn.getAttribute('aria-expanded') !== 'true';
        setOpen(open);
      });

      backdrop?.addEventListener('click', () => setOpen(false));

      menu?.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]').forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggleBtn.getAttribute('aria-expanded') === 'true') setOpen(false);
      });

      // Close menu if viewport grows to desktop
      const mq = window.matchMedia('(min-width: 768px)');
      const onMq = () => { if (mq.matches) setOpen(false); };
      mq.addEventListener?.('change', onMq);

      // Close before Astro transitions to avoid stuck scroll-lock
      document.addEventListener('astro:before-preparation', () => setOpen(false), { once: false });
    }

    // Theme toggle — bind idempotently too
    if (themeBtn && !(themeBtn as any).__themeBound) {
      (themeBtn as any).__themeBound = true;
      themeBtn.addEventListener('click', () => {
        const nowDark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', nowDark);
        try { localStorage.setItem('theme', nowDark ? 'dark' : 'light'); } catch {}
        syncThemeIcons();
      });
    }
    syncThemeIcons();
  }

  function syncThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    // Sun visible when dark (tap to go light). Moon visible when light (tap to go dark).
    document.querySelectorAll<HTMLElement>('.theme-icon-sun').forEach((el) => {
      el.style.display = isDark ? 'block' : 'none';
    });
    document.querySelectorAll<HTMLElement>('.theme-icon-moon').forEach((el) => {
      el.style.display = isDark ? 'none' : 'block';
    });
  }

  initNav();
  // Re-bind after every Astro client-side navigation (ClientRouter swaps DOM)
  document.addEventListener('astro:page-load', initNav);
</script>
