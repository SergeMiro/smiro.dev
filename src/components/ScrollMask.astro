---
/**
 * SVG Mask Scroll Transition
 * Inspired by tympanus.net/Tutorials/SVGMaskScrollTransition
 *
 * Usage: Wrap a section to reveal it through an expanding SVG mask on scroll.
 * <ScrollMask><div>Content revealed via mask</div></ScrollMask>
 */
interface Props {
  /** Number of grid columns for mask pattern */
  cols?: number;
  /** Number of grid rows */
  rows?: number;
  /** 'grid' | 'blinds' | 'circle' */
  pattern?: 'grid' | 'blinds' | 'circle';
}

const { cols = 8, rows = 6, pattern = 'grid' } = Astro.props;
const id = `mask-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="scroll-mask-section" data-scroll-mask data-mask-id={id} data-pattern={pattern}>
  <!-- SVG Mask definition -->
  <svg class="scroll-mask-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <mask id={id}>
        <!-- White = visible, black = hidden -->
        <rect width="100" height="100" fill="black" />
        {pattern === 'grid' && (
          Array.from({ length: rows }).map((_, r) =>
            Array.from({ length: cols }).map((_, c) => (
              <rect
                class="mask-cell"
                x={c * (100 / cols)}
                y={r * (100 / rows)}
                width={100 / cols}
                height={100 / rows}
                fill="white"
                transform={`scale(0)`}
                data-cell={`${r}-${c}`}
                style={`transform-origin: ${c * (100/cols) + 50/cols}% ${r * (100/rows) + 50/rows}%`}
              />
            ))
          )
        )}
        {pattern === 'blinds' && (
          Array.from({ length: 12 }).map((_, i) => (
            <rect
              class="mask-cell"
              x="0"
              y={i * (100 / 12)}
              width="100"
              height={100 / 12}
              fill="white"
              transform="scaleY(0)"
              style={`transform-origin: 50% ${i * (100/12) + 50/12}%`}
            />
          ))
        )}
        {pattern === 'circle' && (
          <circle
            class="mask-cell"
            cx="50"
            cy="50"
            r="0"
            fill="white"
          />
        )}
      </mask>
    </defs>
  </svg>

  <!-- Masked content -->
  <div class="scroll-mask-content" style={`mask: url(#${id}); -webkit-mask: url(#${id});`}>
    <slot />
  </div>
</div>

<style>
  .scroll-mask-section {
    position: relative;
  }

  .scroll-mask-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .scroll-mask-svg rect,
  .scroll-mask-svg circle {
    shape-rendering: crispEdges;
  }

  .scroll-mask-content {
    position: relative;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('[data-scroll-mask]').forEach((section) => {
    const maskId = (section as HTMLElement).dataset.maskId;
    const pattern = (section as HTMLElement).dataset.pattern;
    const cells = section.querySelectorAll('.mask-cell');
    if (!cells.length) return;

    if (pattern === 'grid') {
      // Randomize order for reveal
      const shuffled = gsap.utils.shuffle(Array.from(cells));

      gsap.fromTo(shuffled, {
        attr: { transform: 'scale(0)' },
      }, {
        attr: { transform: 'scale(1)' },
        duration: 1,
        ease: 'power2.inOut',
        stagger: {
          each: 0.02,
          from: 'random',
        },
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: 'top 20%',
          scrub: 2,
        },
      });
    }

    if (pattern === 'blinds') {
      gsap.fromTo(cells, {
        attr: { transform: 'scaleY(0)' },
      }, {
        attr: { transform: 'scaleY(1)' },
        duration: 1,
        ease: 'power2.inOut',
        stagger: {
          each: 0.04,
          from: 'center',
        },
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: 'top 20%',
          scrub: 2.5,
        },
      });
    }

    if (pattern === 'circle') {
      gsap.fromTo(cells, {
        attr: { r: 0 },
      }, {
        attr: { r: 75 },
        duration: 1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: 'top 10%',
          scrub: 2,
        },
      });
    }
  });
</script>
