---
---

<div id="view-mode-toggle" class="fixed bottom-6 right-6 z-[90] flex flex-col items-end gap-2">
  <!-- Panel (hidden by default) -->
  <div
    id="view-mode-panel"
    class="hidden mb-2 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur-xl shadow-2xl min-w-[200px]"
  >
    <p class="text-xs font-medium tracking-widest uppercase text-[var(--color-text-faint)] mb-3">
      View Mode
    </p>
    <div class="flex gap-2">
      <button
        data-mode="2d"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 border"
      >
        2D
      </button>
      <button
        data-mode="3d"
        class="mode-btn flex-1 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 border"
      >
        3D
      </button>
    </div>
    <p class="text-[10px] text-[var(--color-text-faint)] mt-2 text-center">
      Page will reload on switch
    </p>
  </div>

  <!-- Gear button -->
  <button
    id="view-mode-gear"
    class="group p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/90 backdrop-blur-xl text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/30 transition-all duration-300 shadow-lg hover:shadow-xl"
    aria-label="View settings"
  >
    <svg
      class="w-5 h-5 transition-transform duration-500 group-hover:rotate-90"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="3" />
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
    </svg>
  </button>
</div>

<script>
  const gear = document.getElementById('view-mode-gear');
  const panel = document.getElementById('view-mode-panel');
  const modeBtns = document.querySelectorAll('.mode-btn');
  const currentMode = localStorage.getItem('viewMode') || '2d';

  // Set active state on buttons
  function updateButtons(mode: string) {
    modeBtns.forEach((btn) => {
      const btnMode = (btn as HTMLElement).dataset.mode;
      if (btnMode === mode) {
        btn.classList.add(
          'bg-[var(--color-primary)]',
          'text-[var(--color-bg)]',
          'border-[var(--color-primary)]'
        );
        btn.classList.remove(
          'bg-transparent',
          'text-[var(--color-text-muted)]',
          'border-[var(--color-border)]',
          'hover:border-[var(--color-primary)]/30',
          'hover:text-[var(--color-text)]'
        );
      } else {
        btn.classList.remove(
          'bg-[var(--color-primary)]',
          'text-[var(--color-bg)]',
          'border-[var(--color-primary)]'
        );
        btn.classList.add(
          'bg-transparent',
          'text-[var(--color-text-muted)]',
          'border-[var(--color-border)]',
          'hover:border-[var(--color-primary)]/30',
          'hover:text-[var(--color-text)]'
        );
      }
    });
  }

  updateButtons(currentMode);

  // Toggle panel
  gear?.addEventListener('click', () => {
    panel?.classList.toggle('hidden');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const toggle = document.getElementById('view-mode-toggle');
    if (toggle && !toggle.contains(e.target as Node)) {
      panel?.classList.add('hidden');
    }
  });

  // Mode switch
  modeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = (btn as HTMLElement).dataset.mode;
      if (mode && mode !== currentMode) {
        localStorage.setItem('viewMode', mode);
        window.location.reload();
      }
    });
  });
</script>
