---
const projects = [
  {
    name: 'Vistalid',
    description: 'AI-powered back-office automation for French companies. Smart email parsing, ticket routing, URSSAF integration.',
    stack: ['Next.js', 'Claude API', 'PostgreSQL', 'n8n', 'Docker'],
    highlight: 'Reduces manual work by 80%',
    status: 'Production',
    featured: true,
  },
  {
    name: 'SimplifyEU',
    description: 'AI solutions for EU business compliance and workflow automation. Multi-language support.',
    stack: ['Python', 'LangChain', 'Supabase', 'FastAPI'],
    status: 'Active',
    github: 'https://github.com/SergeMiro/SimplifyEU',
  },
  {
    name: 'API Téléphonie SDA',
    description: 'Telephony API integration with real-time call data processing and T-SQL analytics.',
    stack: ['T-SQL', 'SQL Server', 'JavaScript', 'REST API'],
    status: 'Production',
    github: 'https://github.com/SergeMiro/API-Telephonie-SDA',
  },
];
---

<section id="projects" class="py-24 md:py-32 bg-[var(--color-surface)]">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex items-end justify-between mb-16">
      <h2
        data-split="words"
        class="font-[var(--font-display)] text-[length:var(--text-2xl)] font-bold leading-tight"
      >
        Featured Projects
      </h2>
      <a
        href="/projects"
        class="hidden md:inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
      >
        View all
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Asymmetric grid: large left, two stacked right -->
    <div class="grid md:grid-cols-5 gap-6" data-stagger>
      <!-- Featured (large) -->
      <div class="md:col-span-3 group">
        <div class="h-full rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)] p-8 md:p-10 hover:border-[var(--color-primary)]/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[var(--color-primary)]/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-2 py-0.5 rounded text-[10px] font-medium tracking-wider uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
              {projects[0].status}
            </span>
            {projects[0].highlight && (
              <span class="text-xs text-[var(--color-primary)]">{projects[0].highlight}</span>
            )}
          </div>
          <h3 class="font-[var(--font-display)] text-2xl md:text-3xl font-bold mb-3">
            {projects[0].name}
          </h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
            {projects[0].description}
          </p>
          <div class="flex flex-wrap gap-2">
            {projects[0].stack.map((tech) => (
              <span class="px-2.5 py-1 rounded-md text-xs bg-[var(--color-surface-offset)] text-[var(--color-text-muted)] border border-[var(--color-border)]">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Two smaller cards stacked -->
      <div class="md:col-span-2 flex flex-col gap-6">
        {projects.slice(1).map((project) => (
          <div class="group flex-1 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 md:p-8 hover:border-[var(--color-primary)]/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[var(--color-primary)]/5">
            <div class="flex items-center justify-between mb-3">
              <span class="px-2 py-0.5 rounded text-[10px] font-medium tracking-wider uppercase bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20">
                {project.status}
              </span>
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--color-text-faint)] hover:text-[var(--color-primary)] transition-colors"
                  aria-label={`${project.name} on GitHub`}
                >
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6.02 0c2.28-1.55 3.28-1.23 3.28-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                </a>
              )}
            </div>
            <h3 class="font-[var(--font-display)] text-xl font-bold mb-2">{project.name}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.stack.map((tech) => (
                <span class="px-2 py-0.5 rounded text-[11px] bg-[var(--color-surface-offset)] text-[var(--color-text-faint)]">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile "View all" -->
    <div class="mt-8 md:hidden text-center">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 text-sm text-[var(--color-primary)]"
      >
        View all projects
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
