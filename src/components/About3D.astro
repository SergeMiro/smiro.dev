---
const stats = [
  { value: '5+', label: 'Years' },
  { value: '140+', label: 'Projects' },
  { value: '44', label: 'Repos' },
  { value: '5', label: 'LLMs' },
];

const stackItems = [
  'Next.js', 'React', 'TypeScript', 'Python', 'Node.js',
  'Claude API', 'GSAP', 'Docker', 'PostgreSQL', 'Tailwind',
];
---

<section class="about-3d" id="about-3d">
  <div class="about-3d__sticky">
    <!-- Grid overlay -->
    <div class="about-3d__grid" aria-hidden="true">
      {Array.from({ length: 6 }).map(() => (
        <div class="about-3d__grid-v" />
      ))}
    </div>

    <!-- Phase 1: Bio text -->
    <div class="about-3d__bio" data-about-bio>
      <p class="about-3d__bio-text" data-about-text>
        I collaborate with agencies and founders to craft digital products that feel alive —
        bringing their vision to life with clean engineering and a touch of AI magic.
      </p>
      <p class="about-3d__bio-text about-3d__bio-text--2" data-about-text-2>
        From Next.js frontends to Python ML pipelines,
        from Docker orchestration to multi-agent LLM systems —
        I work across the entire stack with a bias toward shipping fast.
      </p>
    </div>

    <!-- Phase 2: Stats -->
    <div class="about-3d__stats" data-about-stats>
      {stats.map((stat) => (
        <div class="about-3d__stat" data-about-stat>
          <span class="about-3d__stat-value">{stat.value}</span>
          <span class="about-3d__stat-label">{stat.label}</span>
        </div>
      ))}
    </div>

    <!-- Phase 3: Stack ticker -->
    <div class="about-3d__stack" data-about-stack>
      <div class="about-3d__stack-row">
        {stackItems.map((item) => (
          <span class="about-3d__stack-item">{item}</span>
        ))}
        {stackItems.map((item) => (
          <span class="about-3d__stack-item">{item}</span>
        ))}
      </div>
    </div>

    <!-- Section label -->
    <div class="about-3d__label" data-about-label aria-hidden="true">ABOUT</div>
  </div>
</section>

<style>
  .about-3d {
    height: 400vh;
    position: relative;
  }

  .about-3d__sticky {
    height: 100vh;
    position: sticky;
    top: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    padding: 2rem;
  }

  /* Grid */
  .about-3d__grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    justify-content: space-evenly;
    opacity: 0.04;
  }

  .about-3d__grid-v {
    width: 1px;
    height: 100%;
    background: var(--color-text);
  }

  /* Bio */
  .about-3d__bio {
    max-width: 800px;
    text-align: center;
    z-index: 2;
    position: absolute;
  }

  .about-3d__bio-text {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text);
    margin: 0 0 2rem;
  }

  .about-3d__bio-text--2 {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Stats */
  .about-3d__stats {
    position: absolute;
    display: flex;
    gap: clamp(2rem, 6vw, 6rem);
    z-index: 2;
    opacity: 0;
  }

  .about-3d__stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-3d__stat-value {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
  }

  .about-3d__stat-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Stack ticker */
  .about-3d__stack {
    position: absolute;
    bottom: 15%;
    left: 0;
    width: 100%;
    overflow: hidden;
    z-index: 2;
    opacity: 0;
  }

  .about-3d__stack-row {
    display: flex;
    gap: 2rem;
    white-space: nowrap;
    animation: stack-ticker 25s linear infinite;
  }

  .about-3d__stack-item {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.5vw, 1.1rem);
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    flex-shrink: 0;
  }

  @keyframes stack-ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Section label */
  .about-3d__label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 20rem);
    font-weight: 700;
    color: var(--color-text);
    opacity: 0;
    letter-spacing: -0.02em;
    pointer-events: none;
    z-index: 1;
  }
</style>
