const eras = [era2000, era2005, era2010, era2015, era2020, era2025];
---

<div class="pc-evolution" id="pc-evolution" aria-label="Evolution of computers and web development from 2000 to 2025">
  <!-- Year indicator -->
  <div class="year-display">
    <span class="year-text" id="year-text">2000</span>
  </div>

  <!-- Progress dots -->
  <div class="era-dots" id="era-dots">
    {['2000','2005','2010','2015','2020','2025'].map((y, i) => (
      <button class:list={['era-dot', i === 0 && 'active']} data-era={i} aria-label={y}>
        <span class="dot-year">{y}</span>
      </button>
    ))}
  </div>

  <!-- TV static overlay -->
  <div class="tv-static" id="tv-static">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <filter id="noise-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="6" seed="0" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noise-filter)" opacity="0.8" />
    </svg>
    <div class="scan-lines"></div>
    <!-- Horizontal glitch bars -->
    <div class="glitch-bars"></div>
  </div>

  <!-- Era frames -->
  <div class="eras-container" id="eras-container">
    {eras.map((svg, i) => (
      <div class:list={['era-frame', i === 0 && 'active']} data-era={i} set:html={svg} />
    ))}
  </div>
</div>

<style>
  .pc-evolution {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    aspect-ratio: 600 / 440;
    overflow: hidden;
    border-radius: 16px;
    background: radial-gradient(ellipse at 50% 80%, rgba(255,255,255,0.02) 0%, transparent 70%);
  }

  .eras-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .era-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
  }

  .era-frame.active {
    opacity: 1;
    visibility: visible;
  }

  .era-frame :global(.pc-svg) {
    width: 100%;
    height: 100%;
  }

  .year-display {
    position: absolute;
    top: 8px;
    right: 14px;
    z-index: 10;
    pointer-events: none;
  }

  .year-text {
    font-family: var(--font-display, 'Boska', serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-primary, #5eead4);
    opacity: 0.2;
    line-height: 1;
    text-shadow: 0 0 30px var(--color-primary, #5eead4);
  }

  .era-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 6px 14px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(12px);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .era-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    padding: 0;
  }

  .era-dot:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .era-dot.active {
    background: var(--color-primary, #5eead4);
    width: 24px;
    border-radius: 4px;
    box-shadow: 0 0 12px var(--color-primary, #5eead4), 0 0 4px var(--color-primary, #5eead4);
  }

  .dot-year {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-muted, #7a7874);
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
    pointer-events: none;
  }

  .era-dot:hover .dot-year,
  .era-dot.active .dot-year {
    opacity: 1;
  }

  .tv-static {
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
  }

  .scan-lines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  .glitch-bars {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(transparent 0%, transparent 30%, rgba(0,255,200,0.03) 30.5%, transparent 31%, transparent 60%, rgba(255,0,100,0.02) 60.5%, transparent 61%);
  }

  :global(.power-led) {
    animation: led-blink 3s ease-in-out infinite;
  }

  @keyframes led-blink {
    0%, 90%, 100% { opacity: 1; }
    95% { opacity: 0.3; }
  }

  :global(.screen-2000) {
    animation: crt-flicker 0.08s infinite alternate;
  }

  @keyframes crt-flicker {
    0% { opacity: 0.96; }
    100% { opacity: 1; }
  }

  @media (max-width: 640px) {
    .era-dots {
      gap: 5px;
      padding: 4px 10px;
    }
    .era-dot { width: 6px; height: 6px; }
    .era-dot.active { width: 18px; }
  }
</style>

<script>
  import gsap from 'gsap';

  const container = document.getElementById('pc-evolution');
  if (container) {
    const frames = container.querySelectorAll('.era-frame');
    const dots = container.querySelectorAll('.era-dot');
    const yearText = document.getElementById('year-text');
    const staticOverlay = document.getElementById('tv-static');
    const years = ['2000', '2005', '2010', '2015', '2020', '2025'];
    let currentEra = 0;
    let isAnimating = false;
    let autoplayTimer: any;

    function glitchTransition(toEra: number) {
      if (isAnimating || toEra === currentEra) return;
      isAnimating = true;

      const fromFrame = frames[currentEra] as HTMLElement;
      const toFrame = frames[toEra] as HTMLElement;

      dots[currentEra]?.classList.remove('active');
      dots[toEra]?.classList.add('active');

      const tl = gsap.timeline({
        onComplete: () => {
          currentEra = toEra;
          isAnimating = false;
          startAutoplay();
        },
      });

      // Phase 1: Distortion + static
      tl.to(staticOverlay, { opacity: 1, duration: 0.06 })
        .to(fromFrame, {
          x: () => gsap.utils.random(-12, 12),
          scaleX: () => gsap.utils.random(0.97, 1.03),
          skewX: () => gsap.utils.random(-2, 2),
          duration: 0.04,
          repeat: 4,
          yoyo: true,
        }, '<')
        // Phase 2: Black flash + swap
        .to(staticOverlay, { opacity: 0.9, duration: 0.03 })
        .set(fromFrame, { opacity: 0, visibility: 'hidden', x: 0, scaleX: 1, skewX: 0 })
        .set(toFrame, { opacity: 1, visibility: 'visible', x: 0 })
        .call(() => { if (yearText) yearText.textContent = years[toEra]; })
        // Phase 3: New frame stabilizes
        .to(toFrame, {
          x: () => gsap.utils.random(-6, 6),
          scaleX: () => gsap.utils.random(0.99, 1.01),
          duration: 0.03,
          repeat: 2,
          yoyo: true,
        })
        .to(staticOverlay, { opacity: 0, duration: 0.2, ease: 'power2.out' })
        .set(toFrame, { x: 0, scaleX: 1, skewX: 0 });
    }

    function nextEra() {
      const next = (currentEra + 1) % frames.length;
      glitchTransition(next);
    }

    function startAutoplay() {
      clearTimeout(autoplayTimer);
      autoplayTimer = setTimeout(nextEra, 3500);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const era = parseInt((dot as HTMLElement).dataset.era || '0');
        clearTimeout(autoplayTimer);
        glitchTransition(era);
      });
    });

    container.addEventListener('mouseenter', () => clearTimeout(autoplayTimer));
    container.addEventListener('mouseleave', startAutoplay);

    startAutoplay();

    // Animate noise seed for dynamic static
    const noiseFilter = document.querySelector('#noise-filter feTurbulence');
    if (noiseFilter) {
      let seed = 0;
      setInterval(() => {
        seed = (seed + 1) % 10;
        noiseFilter.setAttribute('seed', String(seed));
      }, 50);
    }
  }
</script>
