</style>

<script>
  import gsap from 'gsap';

  const container = document.getElementById('pc-evolution');
  if (!container) throw new Error('Missing pc-evolution');

  const frames = container.querySelectorAll('.era');
  const dots = container.querySelectorAll('.era-btn');
  const yearNum = document.getElementById('year-num');
  const yearLabel = document.getElementById('year-label');
  const staticOverlay = document.getElementById('tv-static');
  const staticCanvas = document.getElementById('static-canvas') as HTMLCanvasElement;

  const years = ['2000', '2005', '2010', '2015', '2020', '2025'];
  const labels = ['The Dawn', 'Web Standards', 'jQuery Era', 'React Revolution', 'TypeScript + Tailwind', 'AI-Powered'];

  // Raw code for each era (from data attributes would be complex, keep inline)
  const codes: string[] = [
    `<html>\n<body bgcolor="#ffff00">\n <center>\n  <h1>\n   <font color="blue">\n    Welcome to my site!\n   </font>\n  </h1>\n  <marquee>\n   Hello World!\n  </marquee>\n  <br>\n  <img src="cool.gif">\n  <br><br>\n  <a href="links.html">\n   My Links\n  </a>\n  <p>\n   Visitor counter: 0042\n  </p>\n </center>\n</body>\n</html>`,
    `<!DOCTYPE html>\n<html>\n<head>\n <style>\n  body {\n   font-family: Arial;\n   margin: 0;\n  }\n  .header {\n   background: #336699;\n   color: white;\n   padding: 20px;\n  }\n  .nav {\n   background: #eee;\n   padding: 8px;\n  }\n  .nav a {\n   color: #336699;\n   margin: 0 10px;\n  }\n  .content {\n   padding: 20px;\n  }\n </style>\n</head>\n<body>\n <div class="header">\n  <h1>MyBlog</h1>\n </div>\n</body>\n</html>`,
    `$(document).ready(function() {\n  // Smooth scroll\n  $('a[href^="#"]').click(\n    function(e) {\n      e.preventDefault();\n      var target = $(this.hash);\n      $('html, body').animate({\n        scrollTop:\n          target.offset().top\n      }, 800);\n    }\n  );\n\n  // Slider animation\n  $('.slider').each(function() {\n    $(this).animate({\n      opacity: 1,\n      left: '+=50px'\n    }, 500);\n  });\n\n  // Ajax load\n  $.get('/api/data',\n    function(data) {\n      $('#content')\n        .html(data)\n        .fadeIn();\n    }\n  );\n});`,
    `import React from 'react';\nimport './App.css';\n\nconst App = () => {\n  const [count, setCount] =\n    useState(0);\n\n  return (\n    <div className="app">\n      <Header />\n      <Hero\n        title="Dashboard"\n        subtitle="Analytics"\n      />\n      <div className="grid">\n        <Card\n          title="Visitors"\n          value="12.5k"\n          trend="+15%"\n          color="blue"\n        />\n        <Card\n          title="Revenue"\n          value="$24,500"\n          trend="+23%"\n          color="green"\n        />\n      </div>\n      <Chart data={stats} />\n    </div>\n  );\n};\n\nexport default App;`,
    `import { motion } from\n  'framer-motion';\n\ninterface HeroProps {\n  title: string;\n  subtitle?: string;\n}\n\nexport const Hero = ({\n  title,\n  subtitle,\n}: HeroProps) => (\n  <motion.section\n    className="min-h-screen\n      flex items-center\n      bg-gradient-to-b\n      from-gray-950\n      to-black"\n    initial={{ opacity: 0 }}\n    animate={{ opacity: 1 }}\n    transition={{\n      duration: 0.8,\n      ease: 'easeOut'\n    }}\n  >\n    <div className="max-w-7xl\n      mx-auto px-6">\n      <h1 className="text-7xl\n        font-bold text-white">\n        {title}\n      </h1>\n    </div>\n  </motion.section>\n);`,
    `---\n// AI-generated component\nimport { gsap } from 'gsap';\nimport type { Props } from\n  '../types';\n---\n\n<section\n  class="relative min-h-screen\n    flex items-center">\n\n  <!-- AI auto-completed -->\n  <motion.div\n    initial={{ y: 40,\n      opacity: 0 }}\n    animate={{ y: 0,\n      opacity: 1 }}\n    transition={{\n      type: "spring",\n      stiffness: 100\n    }}\n    whileInView={{\n      opacity: 1\n    }}\n    viewport={{\n      once: true\n    }}\n  >\n    <h1 class="text-7xl\n      font-bold">\n      AI Whisperer.\n    </h1>\n  </motion.div>\n</section>`,
  ];

  let currentEra = 0;
  let isAnimating = false;
  let autoTimer: any;
  let typingTimeline: gsap.core.Timeline | null = null;

  // Setup static canvas
  const ctx = staticCanvas?.getContext('2d');
  function drawStatic() {
    if (!ctx || !staticCanvas) return;
    staticCanvas.width = 200;
    staticCanvas.height = 140;
    const imageData = ctx.createImageData(200, 140);
    for (let i = 0; i < imageData.data.length; i += 4) {
      const v = Math.random() * 255;
      imageData.data[i] = v;
      imageData.data[i + 1] = v;
      imageData.data[i + 2] = v;
      imageData.data[i + 3] = Math.random() * 180;
    }
    ctx.putImageData(imageData, 0, 0);
  }

  // Type code character by character
  function typeCode(eraIndex: number) {
    if (typingTimeline) typingTimeline.kill();

    const codeEl = document.getElementById(`code-${eraIndex}`);
    const linesEl = document.getElementById(`lines-${eraIndex}`);
    if (!codeEl || !linesEl) return;

    const code = codes[eraIndex];
    const chars = code.split('');
    let displayed = '';
    let lineCount = 1;

    codeEl.textContent = '';
    linesEl.innerHTML = '<div>1</div>';

    typingTimeline = gsap.timeline();
    const totalDuration = 8; // seconds to type all code
    const charDelay = totalDuration / chars.length;

    chars.forEach((char, i) => {
      typingTimeline!.call(() => {
        displayed += char;
        codeEl.textContent = displayed;
        if (char === '\n') {
          lineCount++;
          linesEl.innerHTML = Array.from({ length: lineCount }, (_, j) => `<div>${j + 1}</div>`).join('');
        }
        // Auto-scroll
        const parent = codeEl.parentElement;
        if (parent) parent.scrollTop = parent.scrollHeight;
      }, [], i * charDelay);
    });

    return typingTimeline;
  }

  function switchEra(toEra: number) {
    if (isAnimating || toEra === currentEra) return;
    isAnimating = true;

    const fromFrame = frames[currentEra] as HTMLElement;
    const toFrame = frames[toEra] as HTMLElement;

    dots[currentEra]?.classList.remove('active');
    dots[toEra]?.classList.add('active');

    // Draw fresh static
    drawStatic();

    const tl = gsap.timeline({
      onComplete: () => {
        currentEra = toEra;
        isAnimating = false;
        typeCode(toEra);
        startAutoplay();
      },
    });

    tl.to(staticOverlay, { opacity: 1, duration: 0.06 })
      .to(fromFrame, {
        x: () => gsap.utils.random(-15, 15),
        scaleX: () => gsap.utils.random(0.96, 1.04),
        skewX: () => gsap.utils.random(-3, 3),
        filter: 'brightness(2) saturate(0)',
        duration: 0.04,
        repeat: 3,
        yoyo: true,
      }, '<')
      .call(() => drawStatic())
      .set(fromFrame, { opacity: 0, visibility: 'hidden', x: 0, scaleX: 1, skewX: 0, filter: 'none' })
      .set(toFrame, { opacity: 1, visibility: 'visible', x: 0, transform: '' })
      .call(() => {
        if (yearNum) yearNum.textContent = years[toEra];
        if (yearLabel) yearLabel.textContent = labels[toEra];
      })
      .to(toFrame, {
        x: () => gsap.utils.random(-8, 8),
        scaleX: () => gsap.utils.random(0.99, 1.01),
        duration: 0.03,
        repeat: 2,
        yoyo: true,
      })
      .to(staticOverlay, { opacity: 0, duration: 0.2, ease: 'power2.out' })
      .set(toFrame, { x: 0, scaleX: 1, skewX: 0, clearProps: 'transform' });
  }

  function startAutoplay() {
    clearTimeout(autoTimer);
    autoTimer = setTimeout(() => {
      switchEra((currentEra + 1) % frames.length);
    }, 12000); // 12s per era (time to type + read)
  }

  // Init
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const era = parseInt((dot as HTMLElement).dataset.era || '0');
      clearTimeout(autoTimer);
      switchEra(era);
    });
  });

  container.addEventListener('mouseenter', () => clearTimeout(autoTimer));
  container.addEventListener('mouseleave', startAutoplay);

  // Start first era typing
  typeCode(0);
  startAutoplay();
</script>
