---
/**
 * PC Evolution Animation — 3D styled SVG illustrations
 * Each era: detailed computer with depth, shadows, glows, reflections
 */

// Shared SVG defs for 3D effects
const sharedDefs = `
  <defs>
    <filter id="shadow-sm" x="-5%" y="-5%" width="120%" height="130%">
      <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#000" flood-opacity="0.5"/>
    </filter>
    <filter id="shadow-lg" x="-10%" y="-5%" width="130%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#000" flood-opacity="0.6"/>
    </filter>
    <filter id="glow-green" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feFlood flood-color="#00ff88" flood-opacity="0.6" result="color"/>
      <feComposite in="color" in2="blur" operator="in" result="glow"/>
      <feMerge><feMergeNode in="glow"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="glow-blue" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feFlood flood-color="#4488ff" flood-opacity="0.6" result="color"/>
      <feComposite in="color" in2="blur" operator="in" result="glow"/>
      <feMerge><feMergeNode in="glow"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="glow-cyan" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feFlood flood-color="#00dfd8" flood-opacity="0.5" result="color"/>
      <feComposite in="color" in2="blur" operator="in" result="glow"/>
      <feMerge><feMergeNode in="glow"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="inner-shadow" x="-5%" y="-5%" width="110%" height="110%">
      <feComponentTransfer in="SourceAlpha"><feFuncA type="table" tableValues="1 0"/></feComponentTransfer>
      <feGaussianBlur stdDeviation="3"/>
      <feOffset dx="0" dy="2" result="offsetblur"/>
      <feFlood flood-color="#000" flood-opacity="0.4" result="color"/>
      <feComposite in2="offsetblur" operator="in"/>
      <feComposite in2="SourceAlpha" operator="in"/>
      <feMerge><feMergeNode in="SourceGraphic"/><feMergeNode/></feMerge>
    </filter>
    <linearGradient id="desk-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#5a4f40"/>
      <stop offset="50%" stop-color="#3a3228"/>
      <stop offset="100%" stop-color="#2a2420"/>
    </linearGradient>
    <linearGradient id="desk-top" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6a5f50" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#4a3f35" stop-opacity="0.3"/>
    </linearGradient>
    <radialGradient id="screen-glow-green" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#00ff88" stop-opacity="0.08"/>
      <stop offset="100%" stop-color="#00ff88" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="screen-glow-blue" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#4488ff" stop-opacity="0.1"/>
      <stop offset="100%" stop-color="#4488ff" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="screen-glow-purple" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#a855f7" stop-opacity="0.08"/>
      <stop offset="100%" stop-color="#a855f7" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="screen-glow-cyan" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#00dfd8" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#00dfd8" stop-opacity="0"/>
    </radialGradient>
  </defs>
`;

// 3D desk element shared across eras
const desk3d = `
  <rect x="20" y="358" width="560" height="22" rx="3" fill="url(#desk-grad)" filter="url(#shadow-sm)"/>
  <rect x="20" y="358" width="560" height="4" rx="2" fill="url(#desk-top)"/>
  <line x1="30" y1="380" x2="30" y2="418" stroke="#3a3228" stroke-width="8" stroke-linecap="round"/>
  <line x1="570" y1="380" x2="570" y2="418" stroke="#3a3228" stroke-width="8" stroke-linecap="round"/>
`;

