    <rect x="130" y="388" width="210" height="4" rx="2" fill="#a89e7e" opacity="0.5"/>
    <g opacity="0.5">
      <rect x="137" y="369" width="196" height="4" rx="1" fill="#bfb494"/>
      <rect x="139" y="376" width="192" height="4" rx="1" fill="#bfb494"/>
      <rect x="141" y="383" width="188" height="3" rx="1" fill="#bfb494"/>
    </g>
  </g>

  <!-- ============ BALL MOUSE 3D ============ -->
  <g filter="url(#shadow-sm)">
    <radialGradient id="mouse2000" cx="45%" cy="35%" r="60%">
      <stop offset="0%" stop-color="#e0d5ba"/>
