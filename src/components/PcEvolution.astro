---

<div class="pc-evo" id="pc-evolution">
  <!-- Year badge -->
  <div class="year-badge" id="year-badge">
    <span class="year-num" id="year-num">{eras[0].year}</span>
    <span class="year-label" id="year-label">{eras[0].label}</span>
  </div>

  <!-- Era navigation -->
  <div class="era-nav" id="era-nav">
    {eras.map((era, i) => (
      <button
        class:list={['era-btn', i === 0 && 'active']}
        data-era={i}
        aria-label={era.year}
      >
        <span class="era-btn-year">{era.year}</span>
      </button>
    ))}
  </div>

  <!-- TV static overlay -->
  <div class="tv-static" id="tv-static">
    <canvas id="static-canvas"></canvas>
    <div class="scan-lines"></div>
  </div>

  <!-- Eras -->
  <div class="eras-wrap" id="eras-wrap">
    {eras.map((era, i) => (
      <div class:list={['era', i === 0 && 'active']} data-era={i}>
        <!-- 3D Computer -->
        <div class={`computer ${era.monitorClass}`}>
          <!-- Monitor 3D shell -->
          <div class="monitor-3d">
            <div class="monitor-top-face"></div>
            <div class="monitor-left-face"></div>
            <div class="monitor-front-face">
              <!-- Screen bezel -->
              <div class="screen-bezel">
                <div class="screen-content">
                  <!-- Split: editor + preview -->
                  <div class="screen-editor">
                    <div class="editor-bar">
                      <div class="editor-dots">
                        <span class="dot-r"></span>
                        <span class="dot-y"></span>
                        <span class="dot-g"></span>
                      </div>
                      <span class="editor-title">{era.editorTitle}</span>
                    </div>
                    <div class={`editor-body ${era.editorTheme}`}>
                      <div class="line-numbers" id={`lines-${i}`}></div>
                      <pre class="code-area"><code id={`code-${i}`} class="typing-code"></code><span class="cursor">|</span></pre>
                    </div>
                  </div>
                  <div class="screen-preview">
                    <div class="preview-bar">
                      <div class="editor-dots">
                        <span class="dot-r"></span>
                        <span class="dot-y"></span>
                        <span class="dot-g"></span>
                      </div>
                      <div class="url-bar">
                        <span class="url-text">{i === 0 ? 'C:\\site\\index.html' : i === 1 ? 'http://myblog.com' : i === 2 ? 'myapp.com' : i === 3 ? 'localhost:3000' : i === 4 ? 'localhost:3000' : 'smiro.dev'}</span>
                      </div>
                    </div>
                    <div class="preview-body" id={`preview-${i}`} set:html={era.previewHtml} />
                  </div>
                </div>
              </div>
              <!-- Power LED -->
              <div class="power-led-wrap">
                <div class="power-led-dot"></div>
              </div>
            </div>
          </div>
          <!-- Stand -->
          <div class="stand-3d">
            <div class="stand-neck"></div>
            <div class="stand-base"></div>
          </div>
          <!-- Keyboard -->
          <div class="keyboard-3d">
            <div class="kb-top"></div>
            <div class="kb-keys">
              <div class="kb-row"></div>
              <div class="kb-row"></div>
              <div class="kb-row short"></div>
              <div class="kb-space"></div>
            </div>
          </div>
        </div>
        <!-- Screen glow on desk -->
        <div class={`desk-glow desk-glow-${i}`}></div>
      </div>
    ))}
  </div>
</div>

<style>
  /* ============================
     CONTAINER
     ============================ */
  .pc-evo {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    border-radius: 16px;
    perspective: 1200px;
  }

  .eras-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .era {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 3%;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.95);
    transition: none;
  }
  .era.active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  /* ============================
     YEAR BADGE
     ============================ */
  .year-badge {
    position: absolute;
    top: 12px;
    right: 16px;
    z-index: 10;
    text-align: right;
    pointer-events: none;
  }
  .year-num {
    display: block;
    font-family: var(--font-display, 'Boska', serif);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary, #5eead4);
    opacity: 0.18;
    text-shadow: 0 0 40px var(--color-primary, #5eead4);
  }
  .year-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted, #7a7874);
    opacity: 0.6;
  }

  /* ============================
     ERA NAVIGATION
     ============================ */
  .era-nav {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 6px;
    padding: 5px 12px;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .era-btn {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    padding: 0;
  }
  .era-btn:hover { background: rgba(255, 255, 255, 0.3); }
  .era-btn.active {
    width: 26px;
    border-radius: 4px;
    background: var(--color-primary, #5eead4);
    box-shadow: 0 0 14px var(--color-primary, #5eead4);
  }
  .era-btn-year {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 9px;
    font-weight: 600;
    color: var(--color-text-muted, #7a7874);
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
    pointer-events: none;
  }
  .era-btn:hover .era-btn-year,
  .era-btn.active .era-btn-year { opacity: 1; }

  /* ============================
     TV STATIC
     ============================ */
  .tv-static {
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
  }
  .tv-static canvas {
    width: 100%;
    height: 100%;
  }
