const eras = [era2000, era2005, era2010, era2015, era2020, era2025];
---

<div class="pc-evolution" id="pc-evolution" aria-label="Evolution of computers and web development from 2000 to 2025">
  <!-- Year indicator -->
  <div class="year-display">
    <span class="year-text" id="year-text">2000</span>
  </div>

  <!-- Progress dots -->
  <div class="era-dots" id="era-dots">
    {['2000','2005','2010','2015','2020','2025'].map((y, i) => (
      <button class:list={['era-dot', i === 0 && 'active']} data-era={i} aria-label={y}>
        <span class="dot-year">{y}</span>
      </button>
    ))}
  </div>

  <!-- TV static overlay -->
  <div class="tv-static" id="tv-static">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <filter id="noise-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="6" seed="0" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noise-filter)" opacity="0.8" />
    </svg>
    <div class="scan-lines"></div>
  </div>

  <!-- Era frames -->
  <div class="eras-container" id="eras-container">
    {eras.map((svg, i) => (
      <div class:list={['era-frame', i === 0 && 'active']} data-era={i} set:html={svg} />
    ))}
  </div>
</div>

<style>
  .pc-evolution {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    aspect-ratio: 600 / 420;
    overflow: hidden;
    border-radius: 12px;
  }

  .eras-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .era-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
  }

  .era-frame.active {
    opacity: 1;
    visibility: visible;
  }

  .era-frame :global(.pc-svg) {
    width: 100%;
    height: 100%;
  }

  .year-display {
    position: absolute;
    top: 12px;
    right: 16px;
    z-index: 10;
    pointer-events: none;
  }

  .year-text {
    font-family: var(--font-display, 'Boska', serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-primary, #5eead4);
    opacity: 0.25;
    line-height: 1;
  }

  .era-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 6px 14px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .era-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    padding: 0;
  }

  .era-dot.active {
    background: var(--color-primary, #5eead4);
    width: 24px;
    border-radius: 4px;
    box-shadow: 0 0 12px var(--color-primary, #5eead4);
  }

  .dot-year {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--color-text-muted, #7a7874);
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
    pointer-events: none;
  }

  .era-dot:hover .dot-year,
  .era-dot.active .dot-year {
    opacity: 1;
  }

  .tv-static {
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
  }

  .scan-lines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  :global(.power-led) {
    animation: led-blink 3s ease-in-out infinite;
  }

  @keyframes led-blink {
    0%, 90%, 100% { opacity: 1; }
    95% { opacity: 0.4; }
  }

  :global(.screen-2000) {
    animation: crt-flicker 0.1s infinite alternate;
  }

  @keyframes crt-flicker {
    0% { opacity: 0.97; }
    100% { opacity: 1; }
  }

  @media (max-width: 640px) {
    .era-dots {
      gap: 5px;
      padding: 4px 10px;
    }
    .era-dot { width: 6px; height: 6px; }
    .era-dot.active { width: 18px; }
  }
</style>

<script>
  import gsap from 'gsap';

  const container = document.getElementById('pc-evolution');
  if (container) {
    const frames = container.querySelectorAll('.era-frame');
    const dots = container.querySelectorAll('.era-dot');
    const yearText = document.getElementById('year-text');
    const staticOverlay = document.getElementById('tv-static');
    const years = ['2000', '2005', '2010', '2015', '2020', '2025'];
    let currentEra = 0;
    let isAnimating = false;
    let autoplayTimer: any;

    function glitchTransition(toEra: number) {
      if (isAnimating || toEra === currentEra) return;
      isAnimating = true;

      const fromFrame = frames[currentEra] as HTMLElement;
      const toFrame = frames[toEra] as HTMLElement;

      dots[currentEra]?.classList.remove('active');
      dots[toEra]?.classList.add('active');

      const tl = gsap.timeline({
        onComplete: () => {
          currentEra = toEra;
          isAnimating = false;
          startAutoplay();
        },
      });

      tl.to(staticOverlay, { opacity: 1, duration: 0.08 })
        .to(fromFrame, {
          x: () => gsap.utils.random(-10, 10),
          scaleX: () => gsap.utils.random(0.98, 1.02),
          duration: 0.05,
          repeat: 3,
          yoyo: true,
        }, '<')
        .set(fromFrame, { opacity: 0, visibility: 'hidden', x: 0, scaleX: 1 })
        .set(toFrame, { opacity: 1, visibility: 'visible', x: 0 })
        .call(() => { if (yearText) yearText.textContent = years[toEra]; })
        .to(toFrame, {
          x: () => gsap.utils.random(-6, 6),
          scaleX: () => gsap.utils.random(0.99, 1.01),
          duration: 0.04,
          repeat: 2,
          yoyo: true,
        })
        .to(staticOverlay, { opacity: 0, duration: 0.15 })
        .set(toFrame, { x: 0, scaleX: 1 });
    }

    function nextEra() {
      const next = (currentEra + 1) % frames.length;
      glitchTransition(next);
    }

    function startAutoplay() {
      clearTimeout(autoplayTimer);
      autoplayTimer = setTimeout(nextEra, 3500);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const era = parseInt((dot as HTMLElement).dataset.era || '0');
        clearTimeout(autoplayTimer);
        glitchTransition(era);
      });
    });

    container.addEventListener('mouseenter', () => clearTimeout(autoplayTimer));
    container.addEventListener('mouseleave', startAutoplay);

    startAutoplay();

    const noiseFilter = document.querySelector('#noise-filter feTurbulence');
    if (noiseFilter) {
      let seed = 0;
      setInterval(() => {
        seed = (seed + 1) % 10;
        noiseFilter.setAttribute('seed', String(seed));
      }, 50);
    }
  }
</script>
