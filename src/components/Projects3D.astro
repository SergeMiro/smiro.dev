---
import { projects } from '../data/projects';
---

<section class="proj-3d" id="projects-3d">
  <div class="proj-3d__sticky">
    <!-- Section title -->
    <div class="proj-3d__title" data-proj-title>
      <h2 class="proj-3d__title-text">WORK</h2>
    </div>

    <!-- Cards container -->
    <div class="proj-3d__cards" data-proj-cards>
      {projects.slice(0, 6).map((project, i) => (
        <div
          class="proj-3d__card"
          data-proj-card={i}
          style={`--card-i: ${i}`}
        >
          <div class="proj-3d__card-inner">
            <div class="proj-3d__card-head">
              <span class="proj-3d__card-cat">{project.category.toUpperCase()}</span>
              {project.status && (
                <span class="proj-3d__card-status">{project.status}</span>
              )}
            </div>
            <h3 class="proj-3d__card-name">{project.name}</h3>
            <p class="proj-3d__card-desc">{project.description}</p>
            <div class="proj-3d__card-stack">
              {project.stack.map((tech) => (
                <span class="proj-3d__card-tech">{tech}</span>
              ))}
            </div>
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="proj-3d__card-link"
                aria-label={`${project.name} on GitHub`}
              >
                View on GitHub &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="proj-3d__cta" data-proj-cta>
      <a href="/projects" class="proj-3d__cta-link">
        View all projects
        <svg class="proj-3d__cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Contact section for 3D mode -->
<section class="contact-3d" id="contact-3d">
  <div class="contact-3d__inner">
    <h2 class="contact-3d__title" data-contact-title>LET'S<br/>WORK</h2>
    <p class="contact-3d__sub" data-contact-sub>Got a project in mind? Let's make it happen.</p>
    <a href="/contact" class="contact-3d__btn" data-contact-btn>
      Hire me &rarr;
    </a>
  </div>
</section>

<style>
  /* ===== PROJECTS ===== */
  .proj-3d {
    height: 500vh;
    position: relative;
  }

  .proj-3d__sticky {
    height: 100vh;
    position: sticky;
    top: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    perspective: 1200px;
  }

  /* Title */
  .proj-3d__title {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .proj-3d__title-text {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 18rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    opacity: 0.04;
    margin: 0;
  }

  /* Cards */
  .proj-3d__cards {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
  }

  .proj-3d__card {
    position: absolute;
    width: clamp(280px, 35vw, 420px);
    transform-style: preserve-3d;
    will-change: transform, opacity;
    opacity: 0;
  }

  .proj-3d__card-inner {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    backdrop-filter: blur(20px);
    transition: border-color 0.3s ease;
  }

  .proj-3d__card-inner:hover {
    border-color: color-mix(in oklch, var(--color-primary) 40%, transparent);
  }

  .proj-3d__card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .proj-3d__card-cat {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    padding: 0.25rem 0.6rem;
    border: 1px solid color-mix(in oklch, var(--color-primary) 30%, transparent);
    border-radius: 4px;
  }

  .proj-3d__card-status {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: #10b981;
    padding: 0.25rem 0.6rem;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 4px;
  }

  .proj-3d__card-name {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.8rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .proj-3d__card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .proj-3d__card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .proj-3d__card-tech {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    padding: 0.2rem 0.5rem;
    background: var(--color-surface-2);
    border-radius: 4px;
  }

  .proj-3d__card-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: opacity 0.2s;
  }

  .proj-3d__card-link:hover {
    opacity: 0.7;
  }

  /* CTA */
  .proj-3d__cta {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    opacity: 0;
  }

  .proj-3d__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .proj-3d__cta-link:hover { opacity: 0.7; }

  .proj-3d__cta-arrow {
    width: 1rem;
    height: 1rem;
  }

  /* ===== CONTACT ===== */
  .contact-3d {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 4rem 2rem;
    text-align: center;
  }

  .contact-3d__inner {
    max-width: 600px;
  }

  .contact-3d__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }

  .contact-3d__sub {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .contact-3d__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    background: var(--color-primary);
    color: var(--color-bg);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .contact-3d__btn:hover {
    background: var(--color-primary-hover);
  }
</style>
