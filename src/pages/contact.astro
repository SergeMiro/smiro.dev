---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with SergeMiro for freelance, consulting, or collaboration.">
  <section class="pt-32 pb-24 md:pb-32">
    <div class="mx-auto max-w-2xl px-6">
      <h1
        data-split="words"
        class="font-[var(--font-display)] text-[length:var(--text-2xl)] font-bold leading-tight mb-4"
      >
        Let's build something
      </h1>
      <p class="text-[var(--color-text-muted)] text-lg mb-12">
        Available for freelance, consulting, and collaborations.
        Drop me a message and I'll get back to you.
      </p>

      <form class="space-y-6" data-reveal>
        <div>
          <label for="name" class="block text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] mb-2">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] placeholder:text-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] placeholder:text-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] placeholder:text-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors resize-none"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-primary)] text-[var(--color-bg)] font-medium rounded-lg hover:bg-[var(--color-primary-hover)] transition-colors"
        >
          Send Message
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4z" />
          </svg>
        </button>
      </form>

      <!-- Social links -->
      <div class="mt-16 pt-8 border-t border-[var(--color-border)]" data-reveal>
        <h2 class="text-xs font-medium tracking-widest uppercase text-[var(--color-text-faint)] mb-4">
          Or find me here
        </h2>
        <div class="flex gap-6">
          <a href="https://github.com/SergeMiro" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
            GitHub
          </a>
          <a href="https://linkedin.com/in/sergemiro" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
            LinkedIn
          </a>
          <a href="mailto:hello@smiro.dev" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
            Email
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
